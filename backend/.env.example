# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database (matches docker-compose.yml — port 5433 to avoid clashing with a local Postgres)
DATABASE_URL="postgresql://movie_night:movie_night_dev@localhost:5433/movie_night?schema=public"

# Auth — fill in before first run
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# TMDB — get a free v3 key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_URL=https://image.tmdb.org/t/p

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
